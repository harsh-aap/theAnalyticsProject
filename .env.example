# Server
PORT=8080
LOG_LEVEL=info

# Kafka
KAFKA_BROKERS=broker-1.kafka.internal:9092,broker-2.kafka.internal:9092
KAFKA_TOPIC=events
KAFKA_DLQ_TOPIC=events.dlq
MAX_IN_FLIGHT=4096

# Shutdown
SHUTDOWN_TIMEOUT_SEC=15

# Rate limiting (requests per second — 0 to disable)
RATE_LIMIT_RPS=10000
RATE_LIMIT_BURST=1000

# Auth — comma-separated, add more for key rotation
API_KEYS=

# Debug endpoint — leave empty in prod to disable /___api_key_get
DEBUG_SECRET=
